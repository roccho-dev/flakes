@import Target :- tsv { resource = "Target.tsv" } .
@import WholeSystemTarget :- tsv { resource = "WholeSystemTarget.tsv" } .
@import Clause :- tsv { resource = "Clause.tsv" } .
@import ClauseFor :- tsv { resource = "ClauseFor.tsv" } .
@import ClauseRole :- tsv { resource = "ClauseRole.tsv" } .
@import SourceRole :- tsv { resource = "SourceRole.tsv" } .
@import CompiledAsFact :- tsv { resource = "CompiledAsFact.tsv" } .
@import GuardrailRequired :- tsv { resource = "GuardrailRequired.tsv" } .
@import GoalEventSource :- tsv { resource = "GoalEventSource.tsv" } .
