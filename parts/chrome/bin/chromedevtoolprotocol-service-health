set -euo pipefail

service_name="chromedevtoolprotocol-service"
schema_version=1

: "${CHROME_SERVICE_ADDR:=127.0.0.1}"
: "${CHROME_SERVICE_PORT:=9222}"
: "${CHROME_SERVICE_APP_MATCH:=https://chatgpt.com}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"
: "${XDG_RUNTIME_DIR:=/run/user/$(id -u)}"

state_dir="$XDG_STATE_HOME/$service_name"
runtime_profile="$state_dir/runtime/profile.current"
sync_file="$state_dir/profile-sync.json"
pid_file="$state_dir/service.pid"
health_file="$state_dir/health.json"
lock_dir="$XDG_RUNTIME_DIR/$service_name"
lock_file="$lock_dir/profile.lock"
timestamp="$(date --iso-8601=seconds)"

mkdir -p "$state_dir" "$lock_dir"
exec 9>"$lock_file"
flock -s 9

errors='[]'

append_error() {
  local scope="$1"
  local code="$2"
  local detail="$3"

  errors="$(jq -c \
    --arg scope "$scope" \
    --arg code "$code" \
    --arg detail "$detail" \
    '. + [{ scope: $scope, code: $code, detail: $detail }]' <<<"$errors")"
}

profile_sync_status="missing"
profile_source_path=""
if [ -f "$sync_file" ] && jq empty "$sync_file" > /dev/null 2>&1; then
  profile_sync_status="$(jq -r '.status // "missing"' "$sync_file")"
  profile_source_path="$(jq -r '.source_path // empty' "$sync_file")"
else
  append_error "profile" "PROFILE_SYNC_METADATA_MISSING" "$sync_file"
fi

process_running=false
process_pid=""
if [ -f "$pid_file" ]; then
  process_pid="$(tr -d '\n' < "$pid_file")"
  if [ -n "$process_pid" ] && kill -0 "$process_pid" 2> /dev/null; then
    process_running=true
  else
    append_error "process" "PID_FILE_STALE" "$pid_file"
  fi
else
  append_error "process" "PID_FILE_MISSING" "$pid_file"
fi

version_ok=false
list_ok=false
browser_ws_url=""
page_count=0
generic_attachable=false
chatgpt_target_found=false
chatgpt_target_url=""

if version_json="$(curl -fsS --max-time 2 "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_PORT/json/version" 2> /dev/null)"; then
  version_ok=true
  browser_ws_url="$(printf '%s' "$version_json" | jq -r '.webSocketDebuggerUrl // empty')"
else
  append_error "cdp" "JSON_VERSION_UNAVAILABLE" "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_PORT/json/version"
fi

if list_json="$(curl -fsS --max-time 2 "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_PORT/json/list" 2> /dev/null)"; then
  list_ok=true
  page_count="$(printf '%s' "$list_json" | jq -r 'map(select(.type == "page")) | length')"
  generic_attachable="$(printf '%s' "$list_json" | jq -r 'any(.[]?; .type == "page" and (.webSocketDebuggerUrl // "") != "")')"
  chatgpt_target="$(printf '%s' "$list_json" | jq -c --arg app "$CHROME_SERVICE_APP_MATCH" 'map(select(.type == "page" and ((.url // "") | startswith($app)))) | .[0] // empty')"
  if [ -n "$chatgpt_target" ]; then
    chatgpt_target_found=true
    chatgpt_target_url="$(printf '%s' "$chatgpt_target" | jq -r '.url // empty')"
  fi
else
  append_error "cdp" "JSON_LIST_UNAVAILABLE" "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_PORT/json/list"
fi

core_status="green"
core_reason_code="OK"

if [ "$profile_sync_status" = "missing" ]; then
  core_status="degraded"
  core_reason_code="PROFILE_SYNC_METADATA_MISSING"
fi

if [ "$version_ok" != true ] || [ "$list_ok" != true ]; then
  core_status="red"
  core_reason_code="CDP_UNHEALTHY"
elif [ "$generic_attachable" != true ]; then
  core_status="degraded"
  core_reason_code="PAGE_TARGET_UNAVAILABLE"
fi

chatgpt_status="probe-failed"
chatgpt_reason_code="TARGET_MISSING"

if [ "$list_ok" != true ]; then
  chatgpt_reason_code="CDP_LIST_UNAVAILABLE"
elif [ "$chatgpt_target_found" != true ]; then
  chatgpt_reason_code="TARGET_MISSING"
else
  chatgpt_reason_code="AUTH_PROBE_NOT_IMPLEMENTED"
fi

recovery_eligible=false
recovery_reason_code="CORE_GREEN"

case "$core_status" in
  red)
    recovery_eligible=true
    recovery_reason_code="CORE_RED"
    exit_code=20
    ;;
  config-error)
    recovery_eligible=true
    recovery_reason_code="CONFIG_ERROR"
    exit_code=30
    ;;
  degraded)
    recovery_reason_code="CORE_DEGRADED"
    exit_code=10
    ;;
  *)
    exit_code=0
    ;;
esac

tmp="$(mktemp "$state_dir/health.XXXXXX")"
jq -n \
  --argjson schema_version "$schema_version" \
  --arg generated_at "$timestamp" \
  --arg service_name "$service_name" \
  --arg addr "$CHROME_SERVICE_ADDR" \
  --argjson port "$CHROME_SERVICE_PORT" \
  --arg health_file "$health_file" \
  --arg core_status "$core_status" \
  --arg core_reason_code "$core_reason_code" \
  --arg profile_sync_status "$profile_sync_status" \
  --arg profile_source_path "$profile_source_path" \
  --arg runtime_profile "$runtime_profile" \
  --argjson process_running "$process_running" \
  --arg process_pid "$process_pid" \
  --argjson version_ok "$version_ok" \
  --argjson list_ok "$list_ok" \
  --arg browser_ws_url "$browser_ws_url" \
  --argjson page_count "$page_count" \
  --argjson generic_attachable "$generic_attachable" \
  --arg chatgpt_status "$chatgpt_status" \
  --arg chatgpt_reason_code "$chatgpt_reason_code" \
  --argjson chatgpt_target_found "$chatgpt_target_found" \
  --arg chatgpt_target_url "$chatgpt_target_url" \
  --arg app_match "$CHROME_SERVICE_APP_MATCH" \
  --argjson recovery_eligible "$recovery_eligible" \
  --arg recovery_reason_code "$recovery_reason_code" \
  --argjson errors "$errors" \
  '{
    schema_version: $schema_version,
    generated_at: $generated_at,
    service: {
      name: $service_name,
      addr: $addr,
      port: $port,
      health_file: $health_file
    },
    core: {
      status: $core_status,
      reason_code: $core_reason_code,
      profile: {
        source_path: $profile_source_path,
        runtime_path: $runtime_profile,
        sync_status: $profile_sync_status,
        source_snapshot_required: true,
        direct_reuse: "forbidden"
      },
      process: {
        running: $process_running,
        pid: (if $process_pid == "" then null else ($process_pid | tonumber?) end)
      },
      cdp: {
        version_ok: $version_ok,
        list_ok: $list_ok,
        browser_ws_url: (if $browser_ws_url == "" then null else $browser_ws_url end)
      },
      target: {
        page_count: $page_count,
        generic_attachable: $generic_attachable
      }
    },
    app: {
      chatgpt: {
        status: $chatgpt_status,
        reason_code: $chatgpt_reason_code,
        match: $app_match,
        target_found: $chatgpt_target_found,
        target_url: (if $chatgpt_target_url == "" then null else $chatgpt_target_url end)
      }
    },
    recovery: {
      eligible: $recovery_eligible,
      reason_code: $recovery_reason_code
    },
    errors: $errors
  }' > "$tmp"
mv "$tmp" "$health_file"
cat "$health_file"
exit "$exit_code"
