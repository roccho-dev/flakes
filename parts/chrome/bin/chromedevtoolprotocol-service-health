set -euo pipefail

service_name="chromedevtoolprotocol-service"
schema_version=1

: "${CHROME_SERVICE_ADDR:=127.0.0.1}"
: "${CHROME_SERVICE_PORT:=9222}"
: "${CHROME_SERVICE_APP_MATCH:=https://chatgpt.com}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"
: "${XDG_RUNTIME_DIR:=/run/user/$(id -u)}"

state_dir="$XDG_STATE_HOME/$service_name"
runtime_profile="$state_dir/runtime/profile.current"
sync_file="$state_dir/profile-sync.json"
pid_file="$state_dir/service.pid"
health_file="$state_dir/health.json"
lock_dir="$XDG_RUNTIME_DIR/$service_name"
lock_file="$lock_dir/profile.lock"
timestamp="$(date --iso-8601=seconds)"

mkdir -p "$state_dir" "$lock_dir"
exec 9>"$lock_file"
flock -s 9

errors='[]'

append_error() {
  local scope="$1"
  local code="$2"
  local detail="$3"

  errors="$(jq -c \
    --arg scope "$scope" \
    --arg code "$code" \
    --arg detail "$detail" \
    '. + [{ scope: $scope, code: $code, detail: $detail }]' <<<"$errors")"
}

profile_sync_status="missing"
profile_source_path=""
if [ -f "$sync_file" ] && jq empty "$sync_file" > /dev/null 2>&1; then
  profile_sync_status="$(jq -r '.status // "missing"' "$sync_file")"
  profile_source_path="$(jq -r '.source_path // empty' "$sync_file")"
else
  append_error "profile" "PROFILE_SYNC_METADATA_MISSING" "$sync_file"
fi

process_running=false
process_pid=""
if [ -f "$pid_file" ]; then
  process_pid="$(tr -d '\n' < "$pid_file")"
  if [ -n "$process_pid" ] && kill -0 "$process_pid" 2> /dev/null; then
    process_running=true
  else
    append_error "process" "PID_FILE_STALE" "$pid_file"
  fi
else
  append_error "process" "PID_FILE_MISSING" "$pid_file"
fi

version_ok=false
list_ok=false
browser_ws_url=""
page_count=0
generic_attachable=false
chatgpt_target_found=false
chatgpt_target_url=""
chatgpt_target_ws_url=""
chatgpt_probe_ok=false
chatgpt_probe_ready_state=""
chatgpt_probe_title=""
chatgpt_probe_network_online=false
chatgpt_probe_composer_found=false
chatgpt_probe_login_found=false
chatgpt_probe_captcha_found=false
chatgpt_probe_verify_human_found=false
chatgpt_probe_blocked_found=false

if version_json="$(curl -fsS --max-time 2 "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_PORT/json/version" 2> /dev/null)"; then
  version_ok=true
  browser_ws_url="$(printf '%s' "$version_json" | jq -r '.webSocketDebuggerUrl // empty')"
else
  append_error "cdp" "JSON_VERSION_UNAVAILABLE" "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_PORT/json/version"
fi

if list_json="$(curl -fsS --max-time 2 "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_PORT/json/list" 2> /dev/null)"; then
  list_ok=true
  page_count="$(printf '%s' "$list_json" | jq -r 'map(select(.type == "page")) | length')"
  generic_attachable="$(printf '%s' "$list_json" | jq -r 'any(.[]?; .type == "page" and (.webSocketDebuggerUrl // "") != "")')"
  chatgpt_target="$(printf '%s' "$list_json" | jq -c --arg app "$CHROME_SERVICE_APP_MATCH" 'map(select(.type == "page" and ((.url // "") | startswith($app)))) | .[0] // empty')"
  if [ -n "$chatgpt_target" ]; then
    chatgpt_target_found=true
    chatgpt_target_url="$(printf '%s' "$chatgpt_target" | jq -r '.url // empty')"
    chatgpt_target_ws_url="$(printf '%s' "$chatgpt_target" | jq -r '.webSocketDebuggerUrl // empty')"
  fi
else
  append_error "cdp" "JSON_LIST_UNAVAILABLE" "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_PORT/json/list"
fi

core_status="green"
core_reason_code="OK"

if [ "$profile_sync_status" = "missing" ]; then
  core_status="degraded"
  core_reason_code="PROFILE_SYNC_METADATA_MISSING"
fi

if [ "$version_ok" != true ] || [ "$list_ok" != true ]; then
  core_status="red"
  core_reason_code="CDP_UNHEALTHY"
elif [ "$generic_attachable" != true ]; then
  core_status="degraded"
  core_reason_code="PAGE_TARGET_UNAVAILABLE"
fi

chatgpt_status="probe-failed"
chatgpt_reason_code="TARGET_MISSING"

if [ "$list_ok" != true ]; then
  chatgpt_reason_code="CDP_LIST_UNAVAILABLE"
elif [ "$chatgpt_target_found" != true ]; then
  chatgpt_reason_code="TARGET_MISSING"
elif [ -z "$chatgpt_target_ws_url" ]; then
  chatgpt_reason_code="TARGET_WS_URL_MISSING"
else
  chatgpt_probe_js=$(cat <<'EOF'
(() => {
  const q = (selector) => document.querySelector(selector);
  const title = document.title || '';
  const bodyText = document.body ? (document.body.innerText || '') : '';
  const loginText = /(log in|sign in|continue with google|continue with microsoft|continue with apple)/i.test(bodyText);
  const challengeTitle = /(just a moment|checking your browser|attention required)/i.test(title);
  const blockedText = challengeTitle || /(verify you are human|human verification|captcha|access denied|temporarily blocked|unusual activity)/i.test(bodyText);
  const verifyHuman = Array.from(document.querySelectorAll('button, a, [role="button"]')).some((el) => {
    const meta = ((el.innerText || '') + ' ' + (el.getAttribute('aria-label') || '') + ' ' + (el.getAttribute('title') || '')).trim();
    return /(verify you are human|human verification|i am human)/i.test(meta);
  });
  const login = !!q('input[type="password"], form[action*="login"], [href*="login"], button[data-testid*="login"]') || loginText;
  const captcha = !!q('iframe[src*="captcha"], [class*="captcha" i], [id*="captcha" i]');
  const composer = !!(q('#prompt-textarea') || q('textarea') || q('[contenteditable="true"]'));
  return {
    title: title,
    ready_state: document.readyState,
    network_online: navigator.onLine,
    composer_found: composer,
    login_found: login,
    captcha_found: captcha,
    verify_human_found: verifyHuman,
    blocked_found: blockedText
  };
})()
EOF
)

  probe_req="$(jq -cn --arg expr "$chatgpt_probe_js" '{ id: 1, method: "Runtime.evaluate", params: { expression: $expr, returnByValue: true, awaitPromise: true } }')"
  if ! probe_resp="$(cdp-bridge call --ws "$chatgpt_target_ws_url" --req "$probe_req" --timeout-ms 5000 2> /dev/null)"; then
    chatgpt_reason_code="AUTH_PROBE_TRANSPORT_FAILED"
    append_error "app" "AUTH_PROBE_TRANSPORT_FAILED" "$chatgpt_target_url"
  elif ! probe_value="$(printf '%s' "$probe_resp" | jq -cer '.result.result.value // empty' 2> /dev/null)"; then
    chatgpt_reason_code="AUTH_PROBE_RESPONSE_INVALID"
    append_error "app" "AUTH_PROBE_RESPONSE_INVALID" "$chatgpt_target_url"
  else
    chatgpt_probe_ok=true
    chatgpt_probe_title="$(printf '%s' "$probe_value" | jq -r '.title // empty')"
    chatgpt_probe_ready_state="$(printf '%s' "$probe_value" | jq -r '.ready_state // empty')"
    chatgpt_probe_network_online="$(printf '%s' "$probe_value" | jq -r '.network_online // false')"
    chatgpt_probe_composer_found="$(printf '%s' "$probe_value" | jq -r '.composer_found // false')"
    chatgpt_probe_login_found="$(printf '%s' "$probe_value" | jq -r '.login_found // false')"
    chatgpt_probe_captcha_found="$(printf '%s' "$probe_value" | jq -r '.captcha_found // false')"
    chatgpt_probe_verify_human_found="$(printf '%s' "$probe_value" | jq -r '.verify_human_found // false')"
    chatgpt_probe_blocked_found="$(printf '%s' "$probe_value" | jq -r '.blocked_found // false')"

    if [ "$chatgpt_probe_network_online" != true ]; then
      chatgpt_status="probe-failed"
      chatgpt_reason_code="NETWORK_OFFLINE"
    elif [ "$chatgpt_probe_captcha_found" = true ] || [ "$chatgpt_probe_verify_human_found" = true ] || [ "$chatgpt_probe_blocked_found" = true ]; then
      chatgpt_status="challenge-blocked"
      chatgpt_reason_code="CHALLENGE_DETECTED"
    elif [ "$chatgpt_probe_login_found" = true ]; then
      chatgpt_status="login-required"
      chatgpt_reason_code="LOGIN_REQUIRED"
    elif [ "$chatgpt_probe_composer_found" = true ]; then
      chatgpt_status="logged-in"
      chatgpt_reason_code="OK"
    elif [ "$chatgpt_probe_ready_state" != complete ]; then
      chatgpt_status="probe-failed"
      chatgpt_reason_code="PAGE_NOT_READY"
    else
      chatgpt_status="probe-failed"
      chatgpt_reason_code="APP_STATE_UNCERTAIN"
    fi
  fi
fi

recovery_eligible=false
recovery_reason_code="CORE_GREEN"

case "$core_status" in
  red)
    recovery_eligible=true
    recovery_reason_code="CORE_RED"
    exit_code=20
    ;;
  config-error)
    recovery_eligible=true
    recovery_reason_code="CONFIG_ERROR"
    exit_code=30
    ;;
  degraded)
    recovery_reason_code="CORE_DEGRADED"
    exit_code=10
    ;;
  *)
    exit_code=0
    ;;
esac

tmp="$(mktemp "$state_dir/health.XXXXXX")"
jq -n \
  --argjson schema_version "$schema_version" \
  --arg generated_at "$timestamp" \
  --arg service_name "$service_name" \
  --arg addr "$CHROME_SERVICE_ADDR" \
  --argjson port "$CHROME_SERVICE_PORT" \
  --arg health_file "$health_file" \
  --arg core_status "$core_status" \
  --arg core_reason_code "$core_reason_code" \
  --arg profile_sync_status "$profile_sync_status" \
  --arg profile_source_path "$profile_source_path" \
  --arg runtime_profile "$runtime_profile" \
  --argjson process_running "$process_running" \
  --arg process_pid "$process_pid" \
  --argjson version_ok "$version_ok" \
  --argjson list_ok "$list_ok" \
  --arg browser_ws_url "$browser_ws_url" \
  --argjson page_count "$page_count" \
  --argjson generic_attachable "$generic_attachable" \
  --arg chatgpt_status "$chatgpt_status" \
  --arg chatgpt_reason_code "$chatgpt_reason_code" \
  --argjson chatgpt_target_found "$chatgpt_target_found" \
  --arg chatgpt_target_url "$chatgpt_target_url" \
  --arg chatgpt_target_ws_url "$chatgpt_target_ws_url" \
  --argjson chatgpt_probe_ok "$chatgpt_probe_ok" \
  --arg chatgpt_probe_title "$chatgpt_probe_title" \
  --arg chatgpt_probe_ready_state "$chatgpt_probe_ready_state" \
  --argjson chatgpt_probe_network_online "$chatgpt_probe_network_online" \
  --argjson chatgpt_probe_composer_found "$chatgpt_probe_composer_found" \
  --argjson chatgpt_probe_login_found "$chatgpt_probe_login_found" \
  --argjson chatgpt_probe_captcha_found "$chatgpt_probe_captcha_found" \
  --argjson chatgpt_probe_verify_human_found "$chatgpt_probe_verify_human_found" \
  --argjson chatgpt_probe_blocked_found "$chatgpt_probe_blocked_found" \
  --arg app_match "$CHROME_SERVICE_APP_MATCH" \
  --argjson recovery_eligible "$recovery_eligible" \
  --arg recovery_reason_code "$recovery_reason_code" \
  --argjson errors "$errors" \
  '{
    schema_version: $schema_version,
    generated_at: $generated_at,
    service: {
      name: $service_name,
      addr: $addr,
      port: $port,
      health_file: $health_file
    },
    core: {
      status: $core_status,
      reason_code: $core_reason_code,
      profile: {
        source_path: $profile_source_path,
        runtime_path: $runtime_profile,
        sync_status: $profile_sync_status,
        source_snapshot_required: true,
        direct_reuse: "forbidden"
      },
      process: {
        running: $process_running,
        pid: (if $process_pid == "" then null else ($process_pid | tonumber?) end)
      },
      cdp: {
        version_ok: $version_ok,
        list_ok: $list_ok,
        browser_ws_url: (if $browser_ws_url == "" then null else $browser_ws_url end)
      },
      target: {
        page_count: $page_count,
        generic_attachable: $generic_attachable
      }
    },
    app: {
      chatgpt: {
        status: $chatgpt_status,
        reason_code: $chatgpt_reason_code,
        match: $app_match,
        target_found: $chatgpt_target_found,
        target_url: (if $chatgpt_target_url == "" then null else $chatgpt_target_url end),
        target_ws_url: (if $chatgpt_target_ws_url == "" then null else $chatgpt_target_ws_url end),
        probe: {
          ok: $chatgpt_probe_ok,
          title: (if $chatgpt_probe_title == "" then null else $chatgpt_probe_title end),
          ready_state: (if $chatgpt_probe_ready_state == "" then null else $chatgpt_probe_ready_state end),
          network_online: $chatgpt_probe_network_online,
          composer_found: $chatgpt_probe_composer_found,
          login_found: $chatgpt_probe_login_found,
          captcha_found: $chatgpt_probe_captcha_found,
          verify_human_found: $chatgpt_probe_verify_human_found,
          blocked_found: $chatgpt_probe_blocked_found
        }
      }
    },
    recovery: {
      eligible: $recovery_eligible,
      reason_code: $recovery_reason_code
    },
    errors: $errors
  }' > "$tmp"
mv "$tmp" "$health_file"
cat "$health_file"
exit "$exit_code"
