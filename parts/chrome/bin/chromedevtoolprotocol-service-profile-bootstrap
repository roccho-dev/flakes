set -euo pipefail

schema_version=1

: "${CHROME_SERVICE_ADDR:=127.0.0.1}"
: "${CHROME_SERVICE_APP_MATCH:=https://chatgpt.com}"
: "${CHROME_SERVICE_BOOTSTRAP_DISPLAY:=:99}"
: "${CHROME_SERVICE_BOOTSTRAP_PORT:=9223}"
: "${CHROME_SERVICE_BOOTSTRAP_RUN_DIR:=}"
: "${CHROME_SERVICE_BOOTSTRAP_UNIT:=}"
: "${CHROME_SERVICE_BOOTSTRAP_URL:=https://chatgpt.com/}"
: "${CHROME_SERVICE_BOOTSTRAP_VNC_PORT:=5901}"
: "${CHROME_SERVICE_PASSWORD_STORE:=basic}"
: "${CHROME_SERVICE_PUBLISHED_SNAPSHOT:=$HOME/.secret/hq/chromium-cdp-profile.snapshot}"
: "${CHROME_SERVICE_SEED_PROFILE:=$HOME/.secret/hq/chromium-cdp-profile-140}"
: "${CHROME_SERVICE_DISABLE_AUTOMATION:=1}"
: "${CHROME_SERVICE_SPOOF_USER_AGENT:=1}"
: "${CHROME_SERVICE_USER_AGENT:=}"
: "${XDG_RUNTIME_DIR:=/run/user/$(id -u)}"

if [ -z "$CHROME_SERVICE_BOOTSTRAP_RUN_DIR" ]; then
  CHROME_SERVICE_BOOTSTRAP_RUN_DIR="$XDG_RUNTIME_DIR/chrome-login-$CHROME_SERVICE_BOOTSTRAP_PORT"
fi

if [ -z "$CHROME_SERVICE_BOOTSTRAP_UNIT" ]; then
  CHROME_SERVICE_BOOTSTRAP_UNIT="chrome-login-$CHROME_SERVICE_BOOTSTRAP_PORT"
fi

run_dir="$CHROME_SERVICE_BOOTSTRAP_RUN_DIR"
unit_name="$CHROME_SERVICE_BOOTSTRAP_UNIT"

seed_profile="$(realpath -m "$CHROME_SERVICE_SEED_PROFILE")"
published_snapshot="$(realpath -m "$CHROME_SERVICE_PUBLISHED_SNAPSHOT")"
run_dir="$(realpath -m "$run_dir")"
guard_dir="$(dirname "$published_snapshot")"
guard_file="$guard_dir/.chromedevtoolprotocol-service.session.lock"

xvfb_log="$run_dir/xvfb.log"
x11vnc_log="$run_dir/x11vnc.log"
chromium_log="$run_dir/chromium.log"
metadata_file="$run_dir/metadata.json"
xvfb_pid_file="$run_dir/xvfb.pid"
x11vnc_pid_file="$run_dir/x11vnc.pid"
chromium_pid_file="$run_dir/chromium.pid"

json_bool() {
  case "$1" in
    true) printf 'true' ;;
    false) printf 'false' ;;
    *) return 1 ;;
  esac
}

print_usage() {
  cat <<'EOF'
chromedevtoolprotocol-service-profile-bootstrap

usage:
  chromedevtoolprotocol-service-profile-bootstrap start
  chromedevtoolprotocol-service-profile-bootstrap verify
  chromedevtoolprotocol-service-profile-bootstrap login-complete
  chromedevtoolprotocol-service-profile-bootstrap stop
  chromedevtoolprotocol-service-profile-bootstrap publish

environment:
  CHROME_SERVICE_BOOTSTRAP_UNIT      systemd --user transient unit name
  CHROME_SERVICE_BOOTSTRAP_RUN_DIR   run dir for logs and pid files
  CHROME_SERVICE_BOOTSTRAP_PORT      CDP port (default: 9223)
  CHROME_SERVICE_BOOTSTRAP_VNC_PORT  VNC port (default: 5901)
  CHROME_SERVICE_BOOTSTRAP_DISPLAY   X11 display (default: :99)
  CHROME_SERVICE_BOOTSTRAP_URL       browser start URL
  CHROME_SERVICE_SEED_PROFILE        mutable headful seed profile
EOF
}

port_open() {
  local host="$1"
  local port="$2"

  bash -c "(echo > /dev/tcp/$host/$port) >/dev/null 2>&1"
}

pid_running() {
  local pid_file="$1"
  local pid

  if [ ! -f "$pid_file" ]; then
    return 1
  fi

  pid="$(tr -d '\n' < "$pid_file")"
  if [ -z "$pid" ]; then
    return 1
  fi

  kill -0 "$pid" 2> /dev/null
}

metadata_json() {
  jq -n \
    --argjson schema_version "$schema_version" \
    --arg action "profile-bootstrap" \
    --arg unit "$unit_name" \
    --arg run_dir "$run_dir" \
    --arg seed_profile "$seed_profile" \
    --arg published_snapshot "$published_snapshot" \
    --arg display "$CHROME_SERVICE_BOOTSTRAP_DISPLAY" \
    --arg addr "$CHROME_SERVICE_ADDR" \
    --argjson cdp_port "$CHROME_SERVICE_BOOTSTRAP_PORT" \
    --argjson vnc_port "$CHROME_SERVICE_BOOTSTRAP_VNC_PORT" \
    --arg bootstrap_url "$CHROME_SERVICE_BOOTSTRAP_URL" \
    --arg chromium_cdp_bin "$(command -v chromium-cdp)" \
    --arg xvfb_log "$xvfb_log" \
    --arg x11vnc_log "$x11vnc_log" \
    --arg chromium_log "$chromium_log" \
    --arg xvfb_pid_file "$xvfb_pid_file" \
    --arg x11vnc_pid_file "$x11vnc_pid_file" \
    --arg chromium_pid_file "$chromium_pid_file" \
    '{
      schema_version: $schema_version,
      action: $action,
      unit: $unit,
      run_dir: $run_dir,
      seed_profile: $seed_profile,
      published_snapshot: $published_snapshot,
      display: $display,
      addr: $addr,
      cdp_port: $cdp_port,
      vnc_port: $vnc_port,
      bootstrap_url: $bootstrap_url,
      chromium_cdp_bin: $chromium_cdp_bin,
      logs: {
        xvfb: $xvfb_log,
        x11vnc: $x11vnc_log,
        chromium: $chromium_log
      },
      pid_files: {
        xvfb: $xvfb_pid_file,
        x11vnc: $x11vnc_pid_file,
        chromium: $chromium_pid_file
      }
    }'
}

emit_verify_json() {
  local unit_active="$1"
  local cdp_up="$2"
  local vnc_up="$3"
  local xvfb_running="$4"
  local x11vnc_running="$5"
  local chromium_running="$6"
  local status="$7"
  local reason_code="$8"

  jq -n \
    --argjson schema_version "$schema_version" \
    --arg action "profile-bootstrap-verify" \
    --arg status "$status" \
    --arg reason_code "$reason_code" \
    --arg unit "$unit_name" \
    --arg run_dir "$run_dir" \
    --arg display "$CHROME_SERVICE_BOOTSTRAP_DISPLAY" \
    --arg seed_profile "$seed_profile" \
    --arg published_snapshot "$published_snapshot" \
    --arg addr "$CHROME_SERVICE_ADDR" \
    --argjson cdp_port "$CHROME_SERVICE_BOOTSTRAP_PORT" \
    --argjson vnc_port "$CHROME_SERVICE_BOOTSTRAP_VNC_PORT" \
    --argjson unit_active "$(json_bool "$unit_active")" \
    --argjson cdp_up "$(json_bool "$cdp_up")" \
    --argjson vnc_up "$(json_bool "$vnc_up")" \
    --argjson xvfb_running "$(json_bool "$xvfb_running")" \
    --argjson x11vnc_running "$(json_bool "$x11vnc_running")" \
    --argjson chromium_running "$(json_bool "$chromium_running")" \
    --arg metadata_file "$metadata_file" \
    --arg xvfb_log "$xvfb_log" \
    --arg x11vnc_log "$x11vnc_log" \
    --arg chromium_log "$chromium_log" \
    --arg xvfb_pid_file "$xvfb_pid_file" \
    --arg x11vnc_pid_file "$x11vnc_pid_file" \
    --arg chromium_pid_file "$chromium_pid_file" \
    '{
      schema_version: $schema_version,
      action: $action,
      status: $status,
      reason_code: $reason_code,
      unit: $unit,
      run_dir: $run_dir,
      display: $display,
      seed_profile: $seed_profile,
      published_snapshot: $published_snapshot,
      addr: $addr,
      cdp_port: $cdp_port,
      vnc_port: $vnc_port,
      checks: {
        unit_active: $unit_active,
        cdp_up: $cdp_up,
        vnc_up: $vnc_up,
        xvfb_running: $xvfb_running,
        x11vnc_running: $x11vnc_running,
        chromium_running: $chromium_running
      },
      files: {
        metadata: $metadata_file,
        logs: {
          xvfb: $xvfb_log,
          x11vnc: $x11vnc_log,
          chromium: $chromium_log
        },
        pid_files: {
          xvfb: $xvfb_pid_file,
          x11vnc: $x11vnc_pid_file,
          chromium: $chromium_pid_file
        }
      }
    }'
}

verify_impl() {
  local unit_active=false
  local cdp_up=false
  local vnc_up=false
  local xvfb_running=false
  local x11vnc_running=false
  local chromium_running=false
  local status="green"
  local reason_code="OK"

  if [ "$(systemctl --user is-active "$unit_name" 2> /dev/null || true)" = "active" ]; then
    unit_active=true
  fi

  if curl -fsS --max-time 2 "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_BOOTSTRAP_PORT/json/version" > /dev/null 2>&1; then
    cdp_up=true
  fi

  if port_open 127.0.0.1 "$CHROME_SERVICE_BOOTSTRAP_VNC_PORT"; then
    vnc_up=true
  fi

  if pid_running "$xvfb_pid_file"; then
    xvfb_running=true
  fi
  if pid_running "$x11vnc_pid_file"; then
    x11vnc_running=true
  fi
  if pid_running "$chromium_pid_file"; then
    chromium_running=true
  fi

  if [ "$unit_active" != true ]; then
    status="red"
    reason_code="UNIT_INACTIVE"
  elif [ "$cdp_up" != true ]; then
    status="red"
    reason_code="CDP_DOWN"
  elif [ "$vnc_up" != true ]; then
    status="red"
    reason_code="VNC_DOWN"
  elif [ "$xvfb_running" != true ] || [ "$x11vnc_running" != true ] || [ "$chromium_running" != true ]; then
    status="degraded"
    reason_code="PID_FILE_STALE"
  fi

  emit_verify_json "$unit_active" "$cdp_up" "$vnc_up" "$xvfb_running" "$x11vnc_running" "$chromium_running" "$status" "$reason_code"

  case "$status" in
    green) return 0 ;;
    degraded) return 10 ;;
    *) return 20 ;;
  esac
}

start_impl() {
  local wait_attempt=0
  local started=false

  mkdir -p "$seed_profile" "$run_dir" "$guard_dir"
  chmod 700 "$seed_profile" "$run_dir"

  if [ "$(systemctl --user is-active "$unit_name" 2> /dev/null || true)" = "active" ]; then
    verify_impl
    return
  fi

  exec 7>"$guard_file"
  if ! flock -n 7; then
    printf '%s\n' "SINGLE_SESSION_LOCKED" >&2
    return 42
  fi
  flock -u 7

  if curl -fsS --max-time 1 "http://$CHROME_SERVICE_ADDR:$CHROME_SERVICE_BOOTSTRAP_PORT/json/version" > /dev/null 2>&1; then
    printf '%s\n' "BOOTSTRAP_PORT_BUSY" >&2
    return 21
  fi

  if port_open 127.0.0.1 "$CHROME_SERVICE_BOOTSTRAP_VNC_PORT"; then
    printf '%s\n' "BOOTSTRAP_VNC_PORT_BUSY" >&2
    return 22
  fi

  systemctl --user reset-failed "$unit_name" > /dev/null 2>&1 || true
  systemd-run --user \
    --unit "$unit_name" \
    --property=Restart=on-failure \
    --property=RestartSec=1 \
    --property=KillMode=control-group \
    --collect \
    --setenv=CHROME_SERVICE_ADDR="$CHROME_SERVICE_ADDR" \
    --setenv=CHROME_SERVICE_APP_MATCH="$CHROME_SERVICE_APP_MATCH" \
    --setenv=CHROME_SERVICE_BOOTSTRAP_DISPLAY="$CHROME_SERVICE_BOOTSTRAP_DISPLAY" \
    --setenv=CHROME_SERVICE_BOOTSTRAP_PORT="$CHROME_SERVICE_BOOTSTRAP_PORT" \
    --setenv=CHROME_SERVICE_BOOTSTRAP_RUN_DIR="$run_dir" \
    --setenv=CHROME_SERVICE_BOOTSTRAP_UNIT="$unit_name" \
    --setenv=CHROME_SERVICE_BOOTSTRAP_URL="$CHROME_SERVICE_BOOTSTRAP_URL" \
    --setenv=CHROME_SERVICE_BOOTSTRAP_VNC_PORT="$CHROME_SERVICE_BOOTSTRAP_VNC_PORT" \
    --setenv=CHROME_SERVICE_PASSWORD_STORE="$CHROME_SERVICE_PASSWORD_STORE" \
    --setenv=CHROME_SERVICE_PUBLISHED_SNAPSHOT="$published_snapshot" \
    --setenv=CHROME_SERVICE_SEED_PROFILE="$seed_profile" \
    --setenv=CHROME_SERVICE_DISABLE_AUTOMATION="$CHROME_SERVICE_DISABLE_AUTOMATION" \
    --setenv=CHROME_SERVICE_SPOOF_USER_AGENT="$CHROME_SERVICE_SPOOF_USER_AGENT" \
    --setenv=CHROME_SERVICE_USER_AGENT="$CHROME_SERVICE_USER_AGENT" \
    "$0" daemon > /dev/null

  while [ "$wait_attempt" -lt 120 ]; do
    if verify_impl > "$run_dir/verify.json" 2> /dev/null; then
      started=true
      break
    fi
    wait_attempt=$((wait_attempt + 1))
    sleep 1
  done

  if [ "$started" != true ]; then
    verify_impl
    return 23
  fi

  cat "$run_dir/verify.json"
}

stop_impl() {
  systemctl --user stop "$unit_name" > /dev/null 2>&1 || true
  systemctl --user reset-failed "$unit_name" > /dev/null 2>&1 || true

  jq -n \
    --argjson schema_version "$schema_version" \
    --arg action "profile-bootstrap-stop" \
    --arg status "green" \
    --arg reason_code "STOPPED" \
    --arg unit "$unit_name" \
    --arg run_dir "$run_dir" \
    '{
      schema_version: $schema_version,
      action: $action,
      status: $status,
      reason_code: $reason_code,
      unit: $unit,
      run_dir: $run_dir
    }'
}

login_complete_impl() {
  local health_json
  local rc

  set +e
  health_json="$(CHROME_SERVICE_PORT="$CHROME_SERVICE_BOOTSTRAP_PORT" CHROME_SERVICE_HEALTH_SCOPE=app chromedevtoolprotocol-service-health 2> /dev/null)"
  rc=$?
  set -e

  if [ -z "$health_json" ]; then
    health_json='null'
  fi

  jq -n \
    --argjson schema_version "$schema_version" \
    --arg action "profile-bootstrap-login-complete" \
    --arg unit "$unit_name" \
    --arg run_dir "$run_dir" \
    --argjson exit_code "$rc" \
    --argjson health "$health_json" \
    '{
      schema_version: $schema_version,
      action: $action,
      unit: $unit,
      run_dir: $run_dir,
      exit_code: $exit_code,
      health: $health,
      login_complete: ($health.app.chatgpt.status == "logged-in")
    }'
}

daemon_impl() {
  local chrome_pid
  local vnc_pid
  local xvfb_pid

  cleanup() {
    set +e
    if [ -n "${chrome_pid:-}" ]; then kill "$chrome_pid" 2> /dev/null || true; wait "$chrome_pid" 2> /dev/null || true; fi
    if [ -n "${vnc_pid:-}" ]; then kill "$vnc_pid" 2> /dev/null || true; wait "$vnc_pid" 2> /dev/null || true; fi
    if [ -n "${xvfb_pid:-}" ]; then kill "$xvfb_pid" 2> /dev/null || true; wait "$xvfb_pid" 2> /dev/null || true; fi
  }
  trap cleanup EXIT INT TERM

  mkdir -p "$seed_profile" "$run_dir"
  mkdir -p "$guard_dir"
  chmod 700 "$seed_profile" "$run_dir"
  : > "$xvfb_log"
  : > "$x11vnc_log"
  : > "$chromium_log"

  exec 8>"$guard_file"
  if ! flock -n 8; then
    printf '%s\n' "SINGLE_SESSION_LOCKED" >&2
    exit 42
  fi

  metadata_json > "$metadata_file"

  Xvfb "$CHROME_SERVICE_BOOTSTRAP_DISPLAY" -screen 0 1280x800x24 -nolisten tcp -ac > "$xvfb_log" 2>&1 &
  xvfb_pid=$!
  printf '%s\n' "$xvfb_pid" > "$xvfb_pid_file"

  for _ in $(seq 1 80); do
    if xdpyinfo -display "$CHROME_SERVICE_BOOTSTRAP_DISPLAY" > /dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done

  x11vnc -display "$CHROME_SERVICE_BOOTSTRAP_DISPLAY" -localhost -rfbport "$CHROME_SERVICE_BOOTSTRAP_VNC_PORT" -forever -shared -nopw > "$x11vnc_log" 2>&1 &
  vnc_pid=$!
  printf '%s\n' "$vnc_pid" > "$x11vnc_pid_file"

  HQ_CHROME_ADDR="$CHROME_SERVICE_ADDR" \
  HQ_CHROME_PORT="$CHROME_SERVICE_BOOTSTRAP_PORT" \
  HQ_CHROME_HEADLESS=0 \
  HQ_CHROME_PROFILE_DIR="$seed_profile" \
  HQ_CHROME_NO_SANDBOX=0 \
  DISPLAY="$CHROME_SERVICE_BOOTSTRAP_DISPLAY" \
  chromium-cdp \
    --disable-gpu \
    --password-store="$CHROME_SERVICE_PASSWORD_STORE" \
    "$CHROME_SERVICE_BOOTSTRAP_URL" \
    > "$chromium_log" 2>&1 &
  chrome_pid=$!
  printf '%s\n' "$chrome_pid" > "$chromium_pid_file"

  wait "$chrome_pid"
}

publish_impl() {
  exec chromedevtoolprotocol-service-profile-publish "$@"
}

cmd="${1:-}"
if [ $# -gt 0 ]; then
  shift
fi

case "$cmd" in
  start)
    start_impl "$@"
    ;;
  verify)
    verify_impl "$@"
    ;;
  login-complete)
    login_complete_impl "$@"
    ;;
  stop)
    stop_impl "$@"
    ;;
  publish)
    publish_impl "$@"
    ;;
  daemon)
    daemon_impl "$@"
    ;;
  ""|-h|--help|help)
    print_usage
    ;;
  *)
    print_usage >&2
    exit 2
    ;;
esac
